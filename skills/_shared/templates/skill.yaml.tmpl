schema_version: "1.1.0"
name: "{{ skill_name }}"
display_name: "{{ display_name }}"
description: "{{ description }}"
version: "0.1.0"

entry:
  type: "manual"
  path: "SKILL.md"

role: "{{ role }}"

composes: []

factory:
  card_types: []

inputs:
  - name: "target"
    type: "string"
    required: true
    description: "Primary target for this run."

outputs:
  report_schema: "skills/_shared/contract/report.schema.json"
  out_dir_layout: "runs/<run_id>/out/"

permissions:
  network: "none"
  filesystem: "workspace-write"

dependencies:
  tools:
    - "bash"
  python: []

tags:
  - "mindspore"
